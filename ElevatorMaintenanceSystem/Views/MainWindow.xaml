<Window x:Class="ElevatorMaintenanceSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Elevator Maintenance System" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="Elevator Maintenance Management System"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"/>
        </Border>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" Margin="40" VerticalAlignment="Center">
            <TextBlock Text="System Status"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <!-- Connection Status -->
            <Border Background="#ECF0F1"
                   Padding="30"
                   CornerRadius="10"
                   Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Database Connection"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ConnectionStatus}"
                               FontSize="14"
                               Foreground="#27AE60"
                               FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <!-- Application Info -->
            <Border Background="#ECF0F1"
                   Padding="30"
                   CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Application Information"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Version: 1.0.0"
                               FontSize="14"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Framework: .NET 8.0 WPF"
                               FontSize="14"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Database: MongoDB"
                               FontSize="14"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
